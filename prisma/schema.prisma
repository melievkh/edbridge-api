generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  fullname  String
  login     String    @unique
  password  String
  phone1    String    @unique
  phone2    String?   @unique
  role      Role
  createdAt DateTime  @default(now())
  birthDate DateTime?

  student Student?
  teacher Teacher?
}

model Student {
  id           String        @id @default(uuid())
  userId       String        @unique
  groupId      String?
  referralCode String?
  status       StudentStatus @default(NEW)

  attendance Attendance[]
  payments   Payment[]
  user       User         @relation(fields: [userId], references: [id])
  vouchers   Voucher[]
  group      Group?       @relation(fields: [groupId], references: [id])
}

model Teacher {
  id     String        @id @default(uuid())
  userId String        @unique
  status TeacherStatus @default(MAIN)

  groups   Group[]
  user     User      @relation(fields: [userId], references: [id])
  subjects Subject[]
}

model Subject {
  id        String  @id @default(uuid())
  name      String  @unique
  teacherId String?

  groups  Group[]
  teacher Teacher? @relation(fields: [teacherId], references: [id])
}

model Group {
  id        String  @id @default(uuid())
  name      String
  level     String?
  teacherId String
  subjectId String
  schedule  String?

  subject  Subject   @relation(fields: [subjectId], references: [id])
  teacher  Teacher   @relation(fields: [teacherId], references: [id])
  students Student[]
}

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  date      DateTime
  status    AttendanceStatus

  student Student @relation(fields: [studentId], references: [id])
}

model Payment {
  id        String        @id @default(uuid())
  studentId String
  amount    Float
  date      DateTime      @default(now())
  method    PaymentMethod
  startDate DateTime      @default(now())
  endDate   DateTime

  student  Student   @relation(fields: [studentId], references: [id])
  vouchers Voucher[]
}

model Voucher {
  id        String    @id @default(uuid())
  code      String    @unique
  discount  Float
  expiresAt DateTime
  studentId String
  createdAt DateTime  @default(now())
  appliedAt DateTime?
  paymentId String?
  used      Boolean   @default(false)

  student Student  @relation(fields: [studentId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  RECEPTIONIST
}

enum StudentStatus {
  NEW
  ACTIVE
  SUSPENDED
  GRADUATED
}

enum TeacherStatus {
  MAIN
  ASSISTANT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}
